{
  "Author": "Ulanzi Dev",
  "Name": "GCP Monitor",
  "Description": "Show CPU and RAM of a Google Cloud (GCE) VM on a key. Switch between logged-in gcloud accounts; click to refresh all keys or open the VM in the browser. Alerts when the machine is down or has no data in the last minutes.",
  "Icon": "assets/icons/icon.png",
  "Version": "1.1.0",
  "Category": "GCP Monitor",
  "CategoryIcon": "assets/icons/category.png",
  "CodePath": "plugin/app.js",
  "Type": "JavaScript",
  "Inspect": "--inspect=127.0.0.1:9231",
  "UUID": "com.ulanzi.ulanzistudio.gcpmonitor",
  "Actions": [
    {
      "Name": "VM CPU / RAM",
      "Icon": "assets/icons/action.png",
      "PropertyInspectorPath": "property-inspector/machine/inspector.html",
      "state": 0,
      "States": [
        { "Name": "Monitor", "Image": "assets/icons/action.png" }
      ],
      "Tooltip": "Monitor CPU and RAM of a GCP Compute Engine instance",
      "UUID": "com.ulanzi.ulanzistudio.gcpmonitor.machine",
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad"],
      "Devices": []
    }
  ],
  "OS": [
    { "Platform": "windows", "MinimumVersion": "10" },
    { "Platform": "mac", "MinimumVersion": "10.11" }
  ],
  "Software": { "MinVersion": "2.1.4" }
}
